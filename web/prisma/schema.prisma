generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

model audit_logs {
  id          Int      @id @default(autoincrement())
  entity_name String   @db.VarChar
  entity_id   String   @db.VarChar
  action      String   @db.VarChar
  timestamp   DateTime @db.Timestamp(6)
  changes     Json?

  @@index([action], map: "ix_audit_logs_action")
  @@index([entity_id], map: "ix_audit_logs_entity_id")
  @@index([entity_name], map: "ix_audit_logs_entity_name")
}

model credit_history {
  id          Int       @id @default(autoincrement())
  credit_id   Int
  event       String    @db.VarChar
  description String?   @db.VarChar
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  credits     credits   @relation(fields: [credit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_credit_history_id")
}

model credit_installments {
  id          Int               @id @default(autoincrement())
  credit_id   Int
  amount      Decimal           @db.Decimal(12, 2)
  due_date    DateTime?         @db.Date
  number      Int               @default(1)
  status      installmentstatus @default(PENDIENTE)
  paid_amount Decimal           @default(0) @db.Decimal(12, 2)
  paid_at     DateTime?         @db.Timestamp(6)
  credits     credits           @relation(fields: [credit_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payments    payments[]

  @@index([id], map: "ix_credit_installments_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model credit_items {
  id           Int     @id @default(autoincrement())
  credit_id    Int
  product_id   String  @db.VarChar
  product_code String? @db.VarChar
  product_name String  @db.VarChar
  quantity     Int
  unit_price   Decimal @db.Decimal(12, 2)
  credits      credits @relation(fields: [credit_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([id], map: "ix_credit_items_id")
  @@index([product_id], map: "ix_credit_items_product_id")
}

model credits {
  id                  Int                   @id @default(autoincrement())
  customer_id         Int
  concept             String                @db.VarChar
  total_amount        Decimal               @db.Decimal(12, 2)
  balance             Decimal               @db.Decimal(12, 2)
  status              creditstatus
  merchant_id         String                @db.Uuid
  installments_count  Int
  created_at          DateTime?             @db.Timestamp(6)
  credit_history      credit_history[]
  credit_installments credit_installments[]
  credit_items        credit_items[]
  customers           customers             @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  merchants           merchants             @relation(fields: [merchant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments            payments[]

  @@index([customer_id], map: "ix_credits_customer_id")
  @@index([id], map: "ix_credits_id")
  @@index([merchant_id], map: "ix_credits_merchant_id")
}

model customers {
  id                  Int       @id @default(autoincrement())
  full_name           String    @db.VarChar
  merchant_id         String    @db.Uuid
  shopify_customer_id BigInt?
  favorable_balance   Decimal   @db.Decimal(12, 2)
  punctuality_score   Decimal?  @db.Decimal(5, 2)
  email               String?   @db.VarChar
  phone               String?   @db.VarChar
  credits             credits[]
  merchants           merchants @relation(fields: [merchant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_customers_id")
  @@index([merchant_id], map: "ix_customers_merchant_id")
  @@index([shopify_customer_id], map: "ix_customers_shopify_customer_id")
}

model merchants {
  id                     String           @id @db.Uuid
  shop_domain            String           @unique @db.VarChar
  access_token           String?          @db.VarChar
  pago_movil_settings    Json?
  transferencia_settings Json?
  credits                credits[]
  customers              customers[]
  payment_tokens         payment_tokens[]
}

model payment_proofs {
  id               Int            @id @default(autoincrement())
  token_id         String         @db.Uuid
  reference_number String         @db.VarChar
  bank_name        String         @db.VarChar
  amount           Decimal        @db.Decimal(12, 2)
  notes            String?        @db.VarChar
  submitted_at     DateTime?      @db.Timestamp(6)
  status           String         @db.VarChar
  payment_tokens   payment_tokens @relation(fields: [token_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model payment_tokens {
  id             String           @id @db.Uuid
  token          String           @unique @db.VarChar
  payment_id     Int
  merchant_id    String           @db.Uuid
  customer_email String           @db.VarChar
  expires_at     DateTime         @db.Timestamp(6)
  used_at        DateTime?        @db.Timestamp(6)
  created_at     DateTime?        @db.Timestamp(6)
  payment_proofs payment_proofs[]
  merchants      merchants        @relation(fields: [merchant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payments       payments         @relation(fields: [payment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model payments {
  id                   Int                  @id @default(autoincrement())
  credit_id            Int
  installment_id       Int?
  amount               Decimal              @db.Decimal(12, 2)
  reference_number     String               @db.VarChar
  payment_date         DateTime?            @db.Timestamp(6)
  created_at           DateTime?            @default(now()) @db.Timestamp(6)
  payment_method       String?              @db.VarChar
  merchant_id          String               @db.Uuid
  status               paymentstatus        @default(EN_REVISION)
  reviewed_at          DateTime?            @db.Timestamp(6)
  reviewed_by          String?              @db.Uuid
  notes                String?              @db.VarChar
  updated_at           DateTime?            @default(now()) @db.Timestamp(6)
  punctuality_value    Decimal?             @db.Decimal(5, 2)
  installments_covered String?              @db.VarChar
  payment_tokens       payment_tokens[]
  credits              credits              @relation(fields: [credit_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  credit_installments  credit_installments? @relation(fields: [installment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([merchant_id, reference_number], map: "uq_payment_reference")
  @@index([id], map: "ix_payments_id")
}

enum creditreputation {
  EXCELENTE
  BUENA
  REGULAR
  MALA
}

enum creditstatus {
  PENDIENTE_ACTIVACION
  EMITIDO
  EN_PROGRESO
  MOROSO
  PAGADO
  CANCELADO
}

enum installmentstatus {
  PENDIENTE
  PAGADA
  VENCIDA
  VENCIDO
}

enum paymentstatus {
  EN_REVISION
  APROBADO
  RECHAZADO
  REGISTRADO
  CANCELADO
}

model Session {
  id                  String    @id
  shop                String    @db.VarChar
  state               String    @db.VarChar
  isOnline            Boolean   @default(false)
  scope               String?   @db.VarChar
  expires             DateTime? @db.Timestamp(6)
  accessToken         String    @db.VarChar
  userId              BigInt?
  firstName           String?   @db.VarChar
  lastName            String?   @db.VarChar
  email               String?   @db.VarChar
  accountOwner        Boolean   @default(false)
  locale              String?   @db.VarChar
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?   @db.VarChar
  refreshTokenExpires DateTime? @db.Timestamp(6)
}
